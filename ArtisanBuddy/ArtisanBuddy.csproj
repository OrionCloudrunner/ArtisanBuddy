<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>0.1.1</Version>
    <AssemblyVersion>0.1.1.0</AssemblyVersion>
    <FileVersion>0.1.1.0</FileVersion>
    <AssemblyName>ArtisanBuddy</AssemblyName>
    <RootNamespace>ArtisanBuddy</RootNamespace>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <OutputPath>bin\x64\$(Configuration)\</OutputPath>
    <PackageProjectUrl>https://github.com/OrionCloudrunner/ArtisanBuddy</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Description>Coordinates GatherBuddy Reborn and Artisan with apartment-only crafting resume and teleport-stall recovery.</Description>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
</Project>
